      "@id": "mealdb:strIngredient2",
      "@type": "xsd:string"
    },
    "strIngredient3": {
      "@id": "mealdb:strIngredient3",
      "@type": "xsd:string"
    },
    "strMeasure1": {
      "@id": "mealdb:strMeasure1",
      "@type": "xsd:string"
    },
    "strMeasure2": {
      "@id": "mealdb:strMeasure2",
      "@type": "xsd:string"
    },
