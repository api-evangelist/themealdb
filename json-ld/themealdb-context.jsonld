      "@id": "mealdb:strMeasure3",
      "@type": "xsd:string"
    },
    "strSource": {
      "@id": "mealdb:strSource",
      "@type": "xsd:string"
    },
    "dateModified": {
      "@id": "mealdb:dateModified",
      "@type": "xsd:string"
    }
  }
}