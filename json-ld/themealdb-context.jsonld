    },
    "strCategoryDescription": {
      "@id": "mealdb:strCategoryDescription",
      "@type": "xsd:string"
    },
    "strArea": {
      "@id": "mealdb:strArea",
      "@type": "xsd:string"
    },
    "strInstructions": {
      "@id": "mealdb:strInstructions",
      "@type": "xsd:string"
    },
    "strTags": {
      "@id": "mealdb:strTags",
      "@type": "xsd:string"
    },
    "strYoutube": {
      "@id": "mealdb:strYoutube",
      "@type": "xsd:string"
    },
    "strIngredient1": {
      "@id": "mealdb:strIngredient1",
      "@type": "xsd:string"
    },
